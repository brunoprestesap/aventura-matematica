# Variáveis de ambiente do Continha Mágica
# Copie este arquivo para .env.local e preencha os valores reais.
# NÃO comite .env.local no repositório.

# PostgreSQL — connection string do banco de dados
# Exemplo para o container Docker local definido em docker-compose.yml:
DATABASE_URL="postgresql://aventura:aventura@localhost:5432/aventura_matematica?schema=public"

# NextAuth — gere com: openssl rand -base64 32
AUTH_SECRET="substitua_por_um_segredo_gerado_com_openssl_rand_base64_32"

# Google OAuth — configure no Google Cloud Console
AUTH_GOOGLE_ID="seu-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="seu-google-client-secret"

# Vercel Cron — protege o endpoint /api/cron/liga
CRON_SECRET="substitua_por_um_segredo_gerado_com_openssl_rand_base64_32"
